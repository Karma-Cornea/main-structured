# Industrial PDF-to-Graph Pipeline Configuration
# ============================================================================
# Copy this file to .env.local and customize for your environment
# .env.local is NOT committed to git and is local to your machine
# ============================================================================

# ============================================================================
# EXECUTION MODE - Choose between: cpu (local testing) or gpu (production)
# ============================================================================
# cpu   = No time restrictions, all processing on CPU. Good for local testing
# gpu   = GPU-accelerated (CUDA), optimized for speed on server hardware
EXECUTION_MODE=gpu


# ============================================================================
# DEVICE CONFIGURATION
# ============================================================================
# Auto-configured based on EXECUTION_MODE, but can override if needed
# cpu     = Intel/ARM CPU processing
# cuda:0  = NVIDIA GPU 0
# cuda:1  = NVIDIA GPU 1 (if available)
# mps     = Apple Metal Performance Shaders
# 
# Leave as AUTO to use default based on EXECUTION_MODE
DEVICE_FOR_DETECTION=AUTO
DEVICE_FOR_SEGMENTATION=AUTO
DEVICE_FOR_EXTRACTION=AUTO
DEVICE_FOR_EMBEDDING=AUTO


# ============================================================================
# PROCESSING TIMEOUTS (seconds)
# ============================================================================
# 0 = No timeout (unlimited processing)
# Use non-zero values for GPU mode to prevent runaway processes
# 
# Examples:
#   CPU mode (local): Leave at 0 for no limits
#   GPU mode (server): Set to 180-300 seconds for safety
TABLE_EXTRACTION_TIMEOUT=0
OCR_PROCESSING_TIMEOUT=0
PDF_RENDER_TIMEOUT=0


# ============================================================================
# MODEL PATHS AND VERSIONS
# ============================================================================
# P&ID Symbol Detection - YOLOv12
PID_YOLO_MODEL=yolov8n.pt

# Zero-shot Object Detection - GroundingDINO
GROUNDING_DINO_MODEL=groundingdino_swint_ogc.pth

# Segmentation - SAM2
SAM_MODEL_TYPE=vit_b
SAM_MODEL_NAME=sam_vit_b_01ec64.pth

# Entity Extraction - GLiNER
GLINER_MODEL=urchade/gliner_medium-v2.1
GLINER_FINETUNED=models/gliner-industrial-v1

# Relation Extraction - GLiREL
GLIREL_MODEL=jackboyla/glirel-large-v0

# Entity Linking - BLINK
BLINK_MODEL=facebook/genre-linking-blink

# Embeddings - BGE-M3
EMBEDDING_MODEL=BAAI/bge-m3

# Reranker - BGE-Reranker-v2
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# Foundation LLM - Qwen 3
QWEN3_MODEL=Qwen/Qwen2.5-0.5B-Instruct
QWEN3_CONTEXT_LENGTH=32768
QWEN3_TEMPERATURE=0.7
QWEN3_MAX_TOKENS=2048

# Time-Series - TimesFM
TIMESFM_MODEL=google/timesfm-1.0-200m
TIMESFM_CONTEXT_LEN=512
TIMESFM_FORECAST_LEN=128

# Remaining Useful Life - Temporal Fusion Transformer
TFT_MODEL=models/tft_rul_predictor
TFT_LOOKBACK=100
TFT_FORECAST=50


# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Neo4j Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=industrial_graph_password

# Qdrant Vector Database
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=industrial_documents


# ============================================================================
# NATIVE BACKEND MODE
# ============================================================================
# Set this to true, 1, or any non-empty value to download and run native
# Neo4j/Qdrant/Redis binaries under ./open-source instead of Docker.
# Use this for Kaggle or environments that do not support Docker.
USE_NATIVE_BACKENDS=true
# Or set KAGGLE_ENV=kaggle in Kaggle-style environments
# KAGGLE_ENV=kaggle


# ============================================================================
# DATA DIRECTORIES
# ============================================================================
STRUCTURED_DATA_DIR=data


# ============================================================================
# FEATURE FLAGS
# ============================================================================
# Enable/disable specific pipeline stages
GRAPHRAG_ENABLED=true
LANGGRAPH_ENABLED=true
ENABLE_PM=true
ENABLE_RUL=true
ENABLE_ANOMALY=true
ENABLE_RCA=true


# ============================================================================
# LOGGING AND DEBUG
# ============================================================================
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Verbose output for troubleshooting
VERBOSE=false


# ============================================================================
# OPTIMIZATION PROFILES
# ============================================================================
# Predefined profiles for common scenarios
# Uncomment one and adjust individual settings as needed

# PROFILE: Local Development
# EXECUTION_MODE=cpu
# TABLE_EXTRACTION_TIMEOUT=0
# LOG_LEVEL=DEBUG

# PROFILE: GPU Server (Production)
# EXECUTION_MODE=gpu
# TABLE_EXTRACTION_TIMEOUT=180
# OCR_PROCESSING_TIMEOUT=300
# LOG_LEVEL=INFO

# PROFILE: Quick Demo (GPU with short timeouts)
# EXECUTION_MODE=gpu
# TABLE_EXTRACTION_TIMEOUT=10
# LOG_LEVEL=INFO
